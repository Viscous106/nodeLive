# Token hygiene — keep Claude's directory searches on real source.
# NOTE: .gitignore already excludes node_modules/.venv*/dist/build/caches and is
# what Claude Code honors for search. This file covers the extra committed noise.

# Build artifacts & deps (also in .gitignore; listed for explicitness)
node_modules/
dist/
build/
.next/
.cache/
.venv*/
__pycache__/
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage

# Large committed lockfiles (huge, low signal for search)
package-lock.json
**/package-lock.json
*.tsbuildinfo

# Logs / runtime / volumes
*.log
tmp/
uploads/
pgdata/
redisdata/
