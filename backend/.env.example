# Copy to backend/.env and fill in real values. Never commit .env.

# --- App ---
ENV=development
DEBUG=true

# --- Database ---
# App connection (async). Local: direct to postgres; prod: via PgBouncer :5433.
DATABASE_URL=postgresql+asyncpg://edustream:localdev@localhost:5432/edustream
# Direct connection for Alembic DDL (bypasses PgBouncer). Optional locally.
DIRECT_DATABASE_URL=postgresql+asyncpg://edustream:localdev@localhost:5432/edustream

# --- Redis (socket.io adapter + Celery broker/result) ---
REDIS_URL=redis://localhost:6379/0

# --- CORS (comma-separated for multiple origins) ---
CORS_ORIGIN=http://localhost:5173

# --- Auth ---
AUTH_SECRET=change-me-to-a-long-random-string
COOKIE_SECURE=false

# --- Zoom Meeting SDK (from Zoom App Marketplace) ---
ZOOM_SDK_KEY=
ZOOM_SDK_SECRET=

# --- Zoom webhooks + Server-to-Server OAuth (Reports API, recordings) ---
ZOOM_WEBHOOK_SECRET_TOKEN=
ZOOM_S2S_ACCOUNT_ID=
ZOOM_S2S_CLIENT_ID=
ZOOM_S2S_CLIENT_SECRET=

# --- AI ---
ANTHROPIC_API_KEY=

# --- Recording storage (Cloudflare R2 / S3-compatible) ---
# Leave blank to disable recording ingest + playback (endpoints 501 gracefully).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT_URL=
RECORDING_URL_TTL_SECS=300
